# Google Maps JavaScript API key
# Get one at: https://console.cloud.google.com/google/maps-apis/
# Enable: Maps JavaScript API, Places API, Geocoding API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional branded backend base for Hail Yes! server-side features.
# Used for PDF generation, evidence candidate lookup, and MRMS proxy/historical
# imagery. If omitted, the app falls back to the current hosted backend.
VITE_HAIL_YES_API_BASE=

# Optional standalone storm-search backend.
# Leave blank to keep Hail Yes! fully standalone and use direct NOAA/IEM sources only.
# If you later stand up your own search API, point this at its /api base.
VITE_STORM_SEARCH_API_BASE=

# Optional report header defaults for generated PDFs
VITE_REPORT_USER_EMAIL=ahmed@theroofdocs.com
VITE_REPORT_REP_NAME=Ahmed Mahmoud
VITE_REPORT_REP_PHONE=(703) 555-0199
VITE_REPORT_REP_EMAIL=ahmed@theroofdocs.com
VITE_REPORT_COMPANY_NAME=The Roof Docs

# Optional direct provider evidence lookups for the standalone app
# If omitted, the app will try sa21's backend evidence endpoint first and then
# fall back to local search packs.
VITE_YOUTUBE_API_KEY=your_youtube_data_api_key
VITE_FLICKR_API_KEY=your_flickr_api_key

# Optional Synoptic Data API token — enables the 5th source in the consilience
# service (surface-obs corroboration via MADIS/CWOP/METAR). Free tier has a
# ~365-day history limit and 5,000 calls/day. Public token only — never the
# master SYNOPTIC_API_KEY.
# Sign up: https://customer.synopticdata.com/  (Roof-ER's token lives in
# ~/.synoptic-token; `set -a && source ~/.synoptic-token && set +a` to load.)
SYNOPTIC_TOKEN=

# Optional mPING API token — enables the 6th source in the consilience service
# (NOAA crowdsourced hail reports). Free, register at:
# https://mping.ou.edu/registration/register/
MPING_API_TOKEN=

# Optional HailTrace API token — enables the 7th source in the consilience
# service (commercial hail-event database, near-real-time + historical).
# Leave blank if not subscribed.
HAILTRACE_API_TOKEN=

# Optional admin-bootstrap PIN. When set, /api/auth/admin-bootstrap requires
# ?pin=<value> or x-bootstrap-pin: <value> header. Without it, anyone reaching
# the URL gets admin (suitable for private/internal deploys only). The SPA
# checks /api/auth/bootstrap-config to know whether to prompt for the PIN.
BOOTSTRAP_PIN=

# Production hardening: when set, /api/admin/* requires Authorization:
# Bearer <ADMIN_TOKEN>. Logged-in users with plan='company' bypass via JWT.
ADMIN_TOKEN=

# Live MRMS hail-band push alert worker. Set to 1 to enable. Default OFF —
# the worker can spam push subs on first deploy if a storm is active and the
# state map starts empty. Flip on once push subs are validated.
HAIL_YES_LIVE_MRMS_ALERT=
