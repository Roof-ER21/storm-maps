{
  "name": "hail-yes",
  "private": true,
  "version": "0.0.0",
  "description": "Property-level hail intelligence, storm swaths, MRMS overlays, evidence workflow, and NOAA-forward reports for roofing professionals.",
  "author": "Roof-ER21",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Roof-ER21/storm-maps.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch --env-file=.env.local server/index.ts",
    "build": "tsc -b && vite build",
    "start": "node --import tsx server/migrate.ts && node --import tsx server/index.ts",
    "worker": "node --import tsx server/migrate.ts && node --import tsx server/worker.ts",
    "db:migrate": "node --env-file=.env.local --import tsx server/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "cache:prewarm": "node --env-file=.env.local --import tsx scripts/prewarm-wind-cache.ts",
    "consilience": "node --env-file=.env.local --import tsx scripts/consilience-debug.ts",
    "backfill:ncei": "node --env-file=.env.local --import tsx scripts/ncei-backfill.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/genai": "^1.48.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@vis.gl/react-google-maps": "^1.7.1",
    "bcryptjs": "^3.0.3",
    "d3-contour": "^4.0.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "pako": "^2.1.0",
    "pdfkit": "^0.18.0",
    "pngjs": "^7.0.0",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/d3-contour": "^3.0.6",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^24.12.0",
    "@types/pako": "^2.0.4",
    "@types/pdfkit": "^0.17.6",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
